# Build artifacts
buddhabrot
buddhabrot.exe
*.exp
*.lib
*.obj
*.o

# Output renders (regenerable, often large)
*.png
*.jpg
!examples/*.jpg

# Histogram dumps (huge — 4.83 GB at 16K, 19.3 GB at 32K).
# IMap is small (~4 MB) and ships with the repo for reproducibility.
*.bin
!imap.bin
*.bin.tmp
*.bin.sha256
*.tmp

# Logs
*.log
*.stderr.log
*.watchdog.log
*.watchdog.attempt
*.watchdog.detail
*.launch.log
*.monitor.log
*.hfsync.log

# Watchdog / supervisor sentinels & state
*.DONE
*.FATAL
*.pid
*.stop
*.hfsync.pid
*.status.html
*.watchdog.state

# Python
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/
.vs/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini
